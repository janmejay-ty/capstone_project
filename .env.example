# LangSmith tracing config (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_key_here

# Qdrant Server/Cloud connection config
# For Qdrant Cloud: set QDRANT_URL to your cluster URL and QDRANT_API_KEY to your API key
# For local Qdrant (via Docker): set QDRANT_URL=http://localhost:6333 and leave QDRANT_API_KEY blank
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_cloud_api_key_here

# OpenAI / Custom Endpoint Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-4o-mini

# SQLite database path override (optional)
# Leave blank to auto-resolve relative to the project root (recommended)
# SQLITE_DB_PATH=C:/path/to/your/database/support.db
